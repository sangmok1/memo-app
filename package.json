{
  "name": "memo-postit",
  "version": "1.1.6",
  "description": "포스트잇 스타일 데스크톱 할일 메모",
  "main": "main.js",
  "author": "sangmok1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sangmok1/memo-app.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dir",
    "build:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip",
    "build:win": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "package:share": "bash scripts/package-share-zip.sh",
    "build:release": "bash scripts/build-release.sh",
    "build:release:signed": "bash scripts/build-release-signed.sh",
    "launch": "bash scripts/launch.sh",
    "install-app": "bash scripts/install-app.sh"
  },
  "build": {
    "appId": "com.memos.app",
    "productName": "Memos",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "extendInfo": {
        "CFBundleDisplayName": "Memos",
        "CFBundleName": "Memos"
      }
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ko", "en_US"]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!archive/*.json",
      "!archive/*.md",
      "!README.md"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
